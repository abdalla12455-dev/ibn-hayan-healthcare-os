{
  "name": "@ibn-hayan/domain",
  "version": "0.0.0",
  "private": true,
  "description": "Bounded-context domain models, use cases, and repository interfaces for Ibn Hayan Healthcare OS. Pure TypeScript: no framework, ORM, or UI dependencies.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./tenancy": {
      "types": "./dist/tenancy/index.d.ts",
      "import": "./dist/tenancy/index.js",
      "require": "./dist/tenancy/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.typecheck.json --noEmit",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
