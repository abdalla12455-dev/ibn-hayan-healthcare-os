{
  "name": "ibn-hayan-healthcare-os",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "build:contracts": "pnpm --filter @ibn-hayan/contracts build",
    "dev:web": "pnpm run build:contracts && pnpm --filter @ibn-hayan/web dev",
    "dev:api": "pnpm run build:contracts && pnpm --filter @ibn-hayan/api start:dev",
    "build": "pnpm -r build",
    "lint": "pnpm run build:contracts && pnpm -r lint",
    "typecheck": "pnpm run build:contracts && pnpm -r typecheck",
    "test": "pnpm run build:contracts && pnpm -r test",
    "test:integration": "pnpm run build:contracts && pnpm --filter @ibn-hayan/api test:integration"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
