{
  "name": "ibn-hayan-healthcare-os",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "build:shared": "pnpm --filter @ibn-hayan/contracts build && pnpm --filter @ibn-hayan/domain build",
    "build:shared:clean": "pnpm --filter @ibn-hayan/contracts exec rm -rf dist && pnpm --filter @ibn-hayan/domain exec rm -rf dist && pnpm run build:shared",
    "dev:web": "pnpm run build:shared && pnpm --filter @ibn-hayan/web dev",
    "dev:api": "pnpm run build:shared && pnpm --filter @ibn-hayan/api start:dev",
    "build": "pnpm run build:shared && pnpm -r build",
    "lint": "pnpm run build:shared && pnpm -r lint",
    "typecheck": "pnpm run build:shared && pnpm -r typecheck",
    "test": "pnpm run build:shared && pnpm -r test",
    "test:integration": "pnpm run build:shared && pnpm --filter @ibn-hayan/api test:integration",
    "test:database": "pnpm run build:shared && pnpm --filter @ibn-hayan/api test:database",
    "test:auth": "pnpm run build:shared && pnpm --filter @ibn-hayan/api test:auth",
    "test:context": "pnpm run build:shared && pnpm --filter @ibn-hayan/api test:context",
    "test:audit:database": "pnpm run build:shared && pnpm --filter @ibn-hayan/api audit:test:database",
    "test:audit:integration": "pnpm run build:shared && pnpm --filter @ibn-hayan/api audit:test:integration"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
