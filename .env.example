# Ibn Hayan Healthcare Operating System — Environment Variable Example
#
# This file documents the environment variables consumed by the canonical
# implementation. Copy it to `.env` and replace the placeholder values with
# real development-environment values. Real `.env` files must never be
# committed to the repository; they are listed in `.gitignore`.
#
# Do NOT use production credentials in development. Use synthesised local
# credentials only. Do NOT use real patient data.

# PostgreSQL connection string used by apps/api for local development.
# Replace USER, PASSWORD, and DATABASE_NAME with your local development values.
# This placeholder is retained because ADR-012 ratifies PostgreSQL as the
# transactional store and ADR-006 records the database strategy. The
# database is not yet connected in this batch; the value is documented so
# that the configuration surface is visible. The web application does not
# require DATABASE_URL in this batch.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME

# PostgreSQL connection string for the DEDICATED AUDIT DATABASE.
# Per ADR-014 (Audit Store and Integrity Strategy), the audit store
# is a dedicated PostgreSQL 17 database separate from the
# transactional store. In development and tests, the audit database
# may run on the same PostgreSQL cluster as the transactional
# database; in production, it may be deployed to separate
# infrastructure. Replace USER, PASSWORD, and AUDIT_DATABASE_NAME
# with your local development values. The audit database is managed
# by an independent Prisma schema and migration history under
# apps/api/prisma-audit/.
AUDIT_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/AUDIT_DATABASE_NAME

# HMAC-SHA-256 integrity key for the audit chain. Per ADR-014, the
# integrity key has at least 256 bits of entropy (32 bytes). The key
# is versioned by AUDIT_INTEGRITY_KEY_VERSION. The key is NEVER
# stored in the audit database. Replace the placeholder with a real
# key in production; production refuses to start when the placeholder
# is present. Generate a key with, for example:
#   openssl rand -base64 48
AUDIT_INTEGRITY_HMAC_KEY=PLACEHOLDER_AUDIT_INTEGRITY_HMAC_KEY_DO_NOT_USE_IN_PRODUCTION

# The version of the audit integrity key. Per ADR-014, the integrity
# key is versioned to support rotation without re-architecture. The
# version is a positive integer that monotonically increases with
# each key rotation. The verifier supports multiple key versions
# simultaneously; each audit record carries the version that
# produced its integrity_hash.
AUDIT_INTEGRITY_KEY_VERSION=1

# HMAC-SHA-256 identifier key for failed-login privacy. Per ADR-014
# and the ninth canonical batch specification, the raw attempted
# email for a failed login is NEVER persisted in audit data.
# Instead, an HMAC of the normalised identifier is stored in
# `subject_identifier_hash` using this key. The identifier key MUST
# be distinct from the integrity key. Replace the placeholder with a
# real key in production; production refuses to start when the
# placeholder is present. Generate a key with, for example:
#   openssl rand -base64 48
AUDIT_IDENTIFIER_HMAC_KEY=PLACEHOLDER_AUDIT_IDENTIFIER_HMAC_KEY_DO_NOT_USE_IN_PRODUCTION

# Port on which apps/api listens for HTTP requests. Defaults to 3001 when unset.
API_PORT=3001

# Origin of the apps/web deployment, used by apps/api for CORS validation.
WEB_ORIGIN=http://localhost:3000

# Base URL of the apps/api HTTP surface, consumed by apps/web.
# The web client reads this value to construct API requests. It must
# include the /api/v1 prefix.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Node.js environment. Use "development" for local development and
# "production" for deployments. When set to "production", the API suppresses
# OpenAPI documentation routes (/api/docs and /api/docs-json).
NODE_ENV=development
