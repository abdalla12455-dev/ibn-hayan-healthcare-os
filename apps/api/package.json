    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:database": "vitest run --config vitest.database.config.ts",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "prebuild": "prisma generate",
    "pretypecheck": "prisma generate",
    "prelint": "prisma generate",
    "pretest": "prisma generate",
    "pretest:integration": "prisma generate",
    "pretest:database": "prisma generate",
    "predev": "prisma generate",
    "prestart:dev": "prisma generate",
    "prestart:debug": "prisma generate",
    "prestart:prod": "prisma generate"
  },
  "dependencies": {
    "@ibn-hayan/contracts": "workspace:*",
    "@ibn-hayan/domain": "workspace:*",
    "@nestjs/common": "^11.0.1",
