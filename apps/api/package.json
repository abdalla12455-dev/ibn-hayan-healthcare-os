{
  "name": "@ibn-hayan/api",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:database": "vitest run --config vitest.database.config.ts",
    "test:auth": "vitest run --config vitest.auth.config.ts",
    "test:context": "vitest run --config vitest.context.config.ts",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "audit:db:validate": "prisma validate --schema prisma-audit/schema.prisma",
    "audit:db:generate": "prisma generate --schema prisma-audit/schema.prisma",
    "audit:db:migrate:deploy": "prisma migrate deploy --config prisma-audit.config.ts",
    "audit:db:migrate:status": "prisma migrate status --config prisma-audit.config.ts",
    "audit:test:database": "vitest run --config vitest.audit-database.config.ts",
    "audit:test:integration": "vitest run --config vitest.audit-integration.config.ts",
    "audit:dispatch": "node --import tsx src/scripts/audit-dispatch.ts",
    "audit:verify": "node --import tsx src/scripts/audit-verify.ts",
    "build:generated": "swc generated --out-dir dist --sync",
    "auth:bootstrap-dev": "node --import tsx src/scripts/auth-bootstrap-dev.ts",
    "preauth:bootstrap-dev": "prisma generate",
    "prebuild": "prisma generate && prisma generate --schema prisma-audit/schema.prisma && rm -rf dist && pnpm build:generated",
    "pretypecheck": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "prelint": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "pretest": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "pretest:integration": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "pretest:database": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "pretest:auth": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "pretest:context": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "preaudit:test:database": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "preaudit:test:integration": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "preaudit:dispatch": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "preaudit:verify": "prisma generate && prisma generate --schema prisma-audit/schema.prisma",
    "predev": "prisma generate && prisma generate --schema prisma-audit/schema.prisma && pnpm build:generated",
    "prestart:dev": "prisma generate && prisma generate --schema prisma-audit/schema.prisma && pnpm build:generated",
    "prestart:debug": "prisma generate && prisma generate --schema prisma-audit/schema.prisma && pnpm build:generated",
    "prestart:prod": "prisma generate && prisma generate --schema prisma-audit/schema.prisma"
  },
  "dependencies": {
    "@ibn-hayan/contracts": "workspace:*",
    "@ibn-hayan/domain": "workspace:*",
    "@ibn-hayan/observability": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.7.0",
    "@swc/core": "^1.15.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.0.0"
  }
}
