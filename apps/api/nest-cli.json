{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": {
      "type": "swc",
      "options": {
        "ignore": [
          "**/*.spec.ts",
          "**/*.e2e-spec.ts",
          "**/*.db-spec.ts",
          "**/*.auth-spec.ts",
          "src/scripts/**"
        ]
      }
    },
    "deleteOutDir": false,
    "tsConfigPath": "tsconfig.build.json"
  }
}
