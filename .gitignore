skills/
node_modules/

# Tool invocation artifacts (not part of project deliverables)
tool-results/

# Environment
.env

# Build artifacts
dist/
build/
.next/
.cache/
coverage/
*.tsbuildinfo

# Prisma generated client output (regenerated by `prisma generate`;
# never committed because it is deterministic and build-time only).
# The schema and reviewed migrations under apps/api/prisma/ ARE
# committed; only the generated client under generated/ is ignored.
generated/
apps/api/generated/

# Local runtime files
.env.local
.env.*.local

# Editor / OS files
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Legacy prototype uploads (user-supplied HTML/JS prototypes)
# These files contain insecure demonstration credentials and non-production
# prototype logic. They are kept locally for reference under /home/z/my-project/upload/
# but must not be tracked by Git. See
# download/docs/99_WORKLOG/LEGACY_PROTOTYPE_EXTRACTION.md §2.11 for the
# SHA-256 source manifest that identifies the exact files used as extraction input.
/upload/

# Preview-server runtime artefacts — never track
# The .preview-logs/ directory contains intentional preview-infrastructure
# scripts (preview-proxy.py, start-api.sh, start-web.sh) that ARE tracked.
# The *.log and *.pid files in the same directory are runtime artefacts
# produced by the preview server; they must not be tracked because they
# are non-deterministic, may be regenerated at any time, and may capture
# transient runtime output that does not belong in version control.
.preview-logs/*.log
.preview-logs/*.pid
