# Strict peer-dependency resolution prevents silent version drift across the monorepo.
strict-peer-dependencies=true
# Workspace packages are linked automatically.
link-workspace-packages=true
# Prefer the local workspace over the registry for workspace packages.
prefer-workspace-packages=true
# Never hoist dependencies that could break isolated package compilation.
hoist-pattern[]=*eslint*
hoist-pattern[]=*prettier*
# Save exact versions to keep the lockfile deterministic.
save-exact=false
# Engine checks ensure Node.js version alignment.
engine-strict=true
